# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_NAME=cakramerp_db
DB_SCHEMA=public
DB_SYNCHRONIZE=false
DB_LOGGING=true
DB_SSL=false
DB_POOL_SIZE=10

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRATION=30d

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_TTL=300

# Document Generation Service
DOCUMENT_SERVICE_URL=http://localhost:8080

# Resend (Email Notifications)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL="Cakra ERP Lab <noreply@cakramerp.id>"

# App Base URL (used in notification action links)
APP_BASE_URL=http://localhost:3000

# FCM (Firebase Cloud Messaging — Android Push)
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# APNs (Apple Push Notification service — iOS Push)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=
APNS_BUNDLE_ID=id.cakramerp.app
APNS_ENVIRONMENT=sandbox
